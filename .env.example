AGENT_DATABASE_URL=sqlite:///./data/agent.db

# Optional: server bind port for `uv run python -m src` (host stays 127.0.0.1).
AGENT_PORT=8001

# LLM — this project uses Gemini for ALL agent steps (see spec/architecture.md).
AGENT_LLM_MODEL=gemini-2.5-pro

# Required: Google AI Studio API key. Put the real value in .env (gitignored) — never commit it.
AGENT_GEMINI_API_KEY=

# Optional: where artefact files (DXF/SVG/JSON/...) are written, per run_id subdirectory.
AGENT_ARTIFACTS_DIR=data/artifacts

# Optional: structlog JSON log level.
# AGENT_LOG_LEVEL=INFO

# Optional: Gemini 2.5 Pro pricing in USD per million tokens (prompts <= 200k tokens).
# Override here if Google changes prices — no code change needed.
AGENT_GEMINI_INPUT_COST_PER_MTOK=1.25
AGENT_GEMINI_OUTPUT_COST_PER_MTOK=10.0
